#!/bin/sh
#

for host in <%= @ssh_hosts.join(' ') %>
do
  key=`mktemp`
  grep $host <%= @install_dir %>/etc/client.keys > $key
  scp -i <%= @install_dir %>/.ssh/id_rsa -B -o UserKnownHostsFile=/dev/null -o StrictHostKeyChecking=no $key ossec@$host:<%= @install_dir %>/etc/client.keys >/dev/null 2>/dev/null
  rm $key
done
